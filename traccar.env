CONFIG_USE_ENVIRONMENT_VARIABLES="true"
DATABASE_DRIVER=com.mysql.cj.jdbc.Driver
DATABASE_URL=jdbc:mysql://database:3306/traccar?zeroDateTimeBehavior=round&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false&allowMultiQueries=true&autoReconnect=true&useUnicode=yes&characterEncoding=UTF-8&sessionVariables=sql_mode=''
DATABASE_USER=traccar
DATABASE_PASSWORD=traccar
DATABASE_REGISTER_UNKNOWN=true

# Enable Kafka forwarding
FORWARD_TYPE=kafka
FORWARD_URL=broker:9092
FORWARD_TOPIC=positions
FORWARD_RETRY_ENABLE=true
FORWARD_RETRY_DELAY=0

EVENT_FORWARD_TYPE=kafka
EVENT_FORWARD_URL=broker:9092
EVENT_FORWARD_TOPIC=events

# Public tunnel URL
WEB_URL=http://vht.tunnel.mussamipawa.com
WEB_ORIGIN=*
