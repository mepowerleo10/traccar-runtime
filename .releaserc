branches: 
  - main
  - name: development
    prerelease: dev

tagFormat: v${version}

plugins:
  - - "@semantic-release/commit-analyzer"
    - releaseRules:
        - type: feat
          release: minor
        - type: fix
          release: patch
        - type: perf
          release: patch
        - type: refactor
          release: patch
        - type: docs
          release: false
        - type: chore
          release: false
  - "@semantic-release/release-notes-generator"

  - - "@semantic-release/changelog"
    - changelogFile: CHANGELOG.md
    
  - - "@semantic-release/exec"
    - prepareCmd: "echo ${nextRelease.version} > VERSION"

  - - "@semantic-release/github"
    - assets:
        - path: VERSION
          label: Version file

  - - "@semantic-release/git"
    - assets:
        - CHANGELOG.md
        - VERSION
      message: "chore(release): ${nextRelease.version} [skip ci]"

ci: true

